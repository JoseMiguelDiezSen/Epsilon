@{
    ViewData["Title"] = "Inicio";
}

<div class="botonColores"></div>

<div style="position:relative; z-index:0; color:white;">
 
    <div class="home-hero">

        <audio autoplay>
            <source src="/media/audio/StillWiz.mp3" type="audio/mpeg">
        </audio>

        <div id="masterContainer">

            <div class="text-center" style="position:relative; z-index:1;">
                <video autoplay loop muted id="videoMadrid">
                    <source src="~/media/videos/madrid.mp4" type="video/mp4">
                    </video>

                    <div class="text-center" style="margin-top:60px;margin-bottom:30px;">
                        <img src="~/media/epsilon.png" alt="" height="150px" width="150px" style="box-shadow: 0px 0px 10px rgba(0, 0, 0, 0.5);border:1px solid yellow" />
                    </div>
                    <div style="height:100%">
                        <h1 style="box-shadow: 0px 0px 5px rgba(0, 0, 0, 0.5);z-index:0;width:auto;border:1px solid yellow"><i class="fa-solid fa-tooth"></i> CLINICAS DENTALES EPSILON <i class="fa-solid fa-tooth"></i></h1>

                        <p style="text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);color:yellow;margin-bottom:110px;"> BY </p>

                        <div class="row" style="height:40%;">
                            <div style="border-radius:100px;margin-bottom:20px;" class="col-md-6">
                                <img src="~/media/JMDnegro.png" alt="" height="70px" width="150px" style="box-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);border: 1px solid yellow" />
                            </div>

                            <div style="border-radius:100px;padding-bottom:20px;" class="col-md-6">
                                <img src="~/media/logoJSMPequeño.png" alt="" height="70px" width="150px" style="box-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);border: 1px solid yellow" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>


            <div class="text-center">
                <button class="btn btn-outline-light" style="margin-top:15px;">ROADMAP</button>
            </div>

        </div>
    </div>

    @section Styles {
        <link href="~/css/Home.css" rel="stylesheet" />
    }

    @section Scripts {
        <script src="~/js/Home.js" asp-append-version="true"></script>
    }