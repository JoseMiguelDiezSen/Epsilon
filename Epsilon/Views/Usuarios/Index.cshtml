@model UsuariosViewModel

@{
    ViewData["Title"] = "Usuarios";
}
@{
     await Html.RenderPartialAsync("_TituloPagina");
}
@{
    await Html.RenderPartialAsync("_MensajesOperaciones");
}
@* <hr style="color:white;">
<h4 class="text-center" style="color:white;"><span class="fa fa-user"></span> Usuarios <span class="fa fa-user"></span></h4>
<hr style="color:white;"> *@

@* <div id="divErrores" class="alert alert-danger" style="display:none"></div> *@

<div id="divErrores" class="alert-overlay" style="display:none;">
    <div class="alert-box alert alert-danger">
        <div id="msgErrores"></div>
        <button id="btnCerrarError" class="btn btn-sm btn-outline-light mt-2">Cerrar</button>
    </div>
</div>

<form id="id_Form" method="post" asp-action="FiltrarUsuarios" onsubmit="return jqPostFiltrar(event, this)">
    <!-- Snackbar Panel -->
    <div align="center" id="snackbar">Usuario creado correctamente</div>

    <button style="background-color:gainsboro;" class="accordion"><span class="fa fa-search"></span> BUSCADOR</button>

    <div class="panel" style="border-bottom:1px solid gainsboro;border-left:1px solid gainsboro;border-right:1px solid gainsboro;background-color:white;box-shadow: inset 0 6px 6px rgba(220,220,220,0.65);">

        <div class="form-group row" style="padding:10px;padding-bottom:20px;">

            @* Nombre *@
            <div class="col-md-2">
                <label class="label">Nombre</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-user"></i></span>
                    <input type="text" class="form-control" placeholder="Ingrese nombre">
                </div>
            </div>
            @* DNI *@
            <div class="col-md-2">
                <label class="label">DNI</label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="fa fa-address-card" aria-hidden="true"></i>
                    </span>
                    <input type="text" class="form-control" placeholder="Ingrese DNI">
                </div>
            </div>
            @* E-Mail *@
            <div class="col-md-2">
                <label class="label">E-Mail</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                    <input type="email" class="form-control" placeholder="Ingrese E-mail">
                </div>
            </div>
            @* Telefono *@
            <div class="col-md-2">
                <label class="label">Teléfono</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-phone"></i></span>
                    <input type="text" class="form-control" placeholder="Ingrese teléfono" style="padding-right:15px;">

                </div>
            </div>
            @* Ciudad *@
            <div class="col-md-2">
                <label class="label">Ciudad</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-user"></i></span>
                    <input type="text" class="form-control" placeholder="Ingrese ciudad">
                </div>
            </div>

            @* Boton Busqueda *@
            <div class="col-md-2">
                <button type="submit" style="float:left;height:30px;width:100px;margin-top:22.5px;" class="btn btn-sm btn-outline-dark fa fa-pull-right" onclick="if (window.PaginadorPrincipal){ PaginadorPrincipal.destroy(); delete window.idPaginadorPrincipal;}">
                    <span class="fa fa-search"> BUSCAR</span>
                </button>
            </div>
        </div>
    </div>

    <input type="hidden" asp-for="PaginaActual" id="PaginaActual" />
    <input type="hidden" asp-for="RegistrosPorPagina" id="RegistrosPorPagina" />
    <input type="hidden" name="RegistrosPaginaActual" id="RegistrosPaginaActual" value="@Model.Usuarios?.Count()" />   
</form>

<hr />


<button id="btnAddUser" type="button" class="btn btn-sm btn-outline-light fa-pull-right" onclick="return jqGetModalAddUser()"><span class="fa fa-plus"></span> Nuevo <b>Usuario</b></button>
<button id="btnImportUsers" type="button" class="btn btn-sm btn-outline-light fa-pull-left" onclick="return jqGetImportarUsuarios()"><i class="fa-regular fa-share-from-square"></i>Importar <b>Usuarios</b></button>
<button id="btnImportUsers" type="button" class="btn btn-sm btn-outline-light fa-pull-left" onclick="return jqGetModalImportUsers()"><i class="fa-solid fa-file-export"></i>Expportar <b>Usuarios</b></button>
<button id="btnSendMail" type="button" class="btn btn-sm btn-outline-light fa-pull-left" onclick="return jqGetModalEnviarCorreo()"><i class="fa-regular fa-envelope-open"></i> Enviar <b>Correo</b></button>
<button id="showSnack" type="button" class="btn btn-sm btn-outline-dark fa-pull-left" onclick="showMessage()"><span class="fa fa-cog"></span> Mostrar <b>Snack</b></button>



<div id="idResultadosFiltro" class="text-center">
    @{
        await Html.RenderPartialAsync("TablaUsuarios", Model.Usuarios);
    }
</div>

@* Paginacion *@
<div id="idPaginadorPrincipal" class="text-center m-1">
    <a class="btn btn-sm btn-outline-light PaginaAnterior" onclick="PaginadorPrincipal.paginaAnterior()">
        <i class="fa fa-angle-double-left" aria-hidden="true"></i> 
 
    </a>
    <span class="m-2 TextoPaginacion" style="color:white;">@Model.PaginaActual</span>
    <a class="btn btn-sm btn-outline-light PaginaSiguiente" onclick="PaginadorPrincipal.paginaSiguiente()">
    <i class="fa fa-angle-double-right" aria-hidden="true"></i>
    </a>
</div>

@section Styles {
    <link href="~/css/Usuarios.css" rel="stylesheet" />
}

@section Scripts {

    @* <script src="~/js/plugins/PopupLoader.js" asp-append-version="true"></script> *@
  
    <script src="~/js/plugins/draggable.js"></script>
    <script src="~/js/site.js"></script>
    <script src="~/js/Paginador.js" asp-append-version="true"></script>
    <script src="~/js/Usuarios.js" asp-append-version="true"></script>
}

@section Modals {
    @* Modal agregar usuario *@
    <div class="modal fade" tabindex="-1" role="dialog" data-bs-backdrop="static" data-keyboard="false" id="addUserModal">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title text-center">
                        <i class="fa fa-user-plus" aria-hidden="true"></i> Alta Usuario
                    </h5>
                    <button type="button" class="btn-close position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <!-- Aquí se insertará el contenido dinámico -->
                </div>
            </div>
        </div>
    </div>

    @* Modal modificar usuario *@
    <div class="modal fade" tabindex="-1" role="dialog" data-bs-backdrop="static" data-keyboard="false" id="updateUserModal">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title text-center">
                        <span class="fa fa-pencil-square" aria-hidden="true"></span>

                         Modificar datos del Usuario
                    </h5>
                    <button type="button" class="btn-close position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <!-- Aquí se insertará el contenido dinámico -->
                </div>
            </div>
        </div>
    </div>

    @* Modal eliminar usuario *@
    <div class="modal fade" tabindex="-1" role="dialog" data-bs-backdrop="static" data-keyboard="false" id="deleteUserModal">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title text-center">
                        <i class="fa fa-user-times" aria-hidden="true"></i>
                         Eliminar usuario
                    </h5>
                    <button type="button" class="btn-close position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <!-- Aquí se insertará el contenido dinámico -->
                </div>
            </div>
        </div>
    </div> 
}

<script>

    var acc = document.getElementsByClassName("accordion");
    var i;

    for (i = 0; i < acc.length; i++) {
    acc[i].addEventListener("click", function() {
    /* Toggle between adding and removing the "active" class,
    to highlight the button that controls the panel */
    this.classList.toggle("active");

    /* Toggle between hiding and showing the active panel */
    var panel = this.nextElementSibling;
    if (panel.style.display === "block") {
    panel.style.display = "none";
    } else {
    panel.style.display = "block";
    }
    });
    }
</script>