@using Negocio.Persistencia.Modelos
@model List<DatosHistoricoPaciente>

<hr>
<h4 class="text-center"><span class="fa-solid fa-user-injured"></span> Historial de @Model.FirstOrDefault()?.NombrePaciente <span class="fa-solid fa-user-injured"></span></h4>
<hr>

@* Tabla Historial Clinico *@
<table class="table table-hover table-striped table-info border-1 border-dark" id="tablaHistorial">
    <thead>
        <tr>
            <th class="d-none">IdCita</th>
            <th>Nombre Paciente </th>

            <th>Inicio Cita</th>
            <th>Fin Cita</th>
            <th>Observaciones</th>
            <th>Medico</th>
            <th>Clinica</th>

            <th>Tratamiento</th>
            
            <th>Precio</th>

            
            <th>Duracion</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var cita in Model)
        {
            <tr>
                <td class="d-none">@cita.IdCita</td>
                <td>@cita.NombrePaciente</td>
                <td>@cita.FechaInicio.ToString("HH:mm")</td>
                <td>@cita.FechaFin.ToString("HH:mm")</td>
                <td>@cita.Observaciones</td>
                <td>@cita.NombreMedico</td>
                <td>@cita.NombreClinica</td>
                <td>@cita.NombreTratamiento</td>
                <td>@cita.Precio €</td>
                <td>@((cita.Duracion / 60.0).ToString("0.0")) h</td>
            </tr>
        }
    </tbody>
</table>

<div style="margin-bottom:15px;" class="fa-pull-right">
    <a class="btn btn-secondary" href="/Pacientes">
        <i class="fa fa-arrow-left" aria-hidden="true"></i> Volver a Pacientes
    </a>
</div>


<div class="row alert alert-secondary d-flex"
     style="padding:10px; align-items:center; gap:10px;">

    <div class="col-md-auto">
        <label style="margin:0;">
            Exportar Historial de @Model.FirstOrDefault()?.NombrePaciente
        </label>
    </div>

    <div class="col-md-auto">
        <select name="modelosExportacion"
                class="form-control form-select"
                title="Listado de Exportaciones" id="modelosExportacion">

            <option value="" selected disabled>(Seleccione una opcion)</option>
            <option value="txt">TXT</option>
            <option value="pdfListado">PDF (Listado)</option>
            <option value="pdfTabla">PDF (Tabla)</option>
            <option value="informe">INFORME</option>
            <option value="pdfListaZip">ZIP</option>
        </select>
    </div>

    <div class="col-md-auto">
        <button id="ayuda"
                type="button"
                class="btn btn-sm btn-outline-dark"
                title="Exportar Historial"
                onclick="jqExportarHistorial(@Model.FirstOrDefault()?.IdPaciente)">

            <i class="fa fa-download" aria-hidden="true"></i>
        </button>
    </div>


    <div class="col-md-auto">
        <strong>Total citas:</strong>
        @Model.Count()
    </div>


    <div class="col-md-auto">
        <strong>Total Importe:</strong>
        @Model.Sum(x => x.Precio) €
    </div>

    <div class="col-md-auto">
        <strong>Total Duracion:</strong>
        @((Model.Sum(x => x.Duracion) / 60.0).ToString("0.0")) h
    </div>

    <div class="col-md-auto">
        <strong>Primera cita:</strong>
        @Model.Min(x => x.FechaInicio).ToShortDateString()
    </div>

    <div class="col-md-auto">
        <strong>Última cita:</strong>
        @Model.Max(x => x.FechaInicio).ToShortDateString()
    </div>


</div>

@section Styles {
    <link href="~/css/HistorialPaciente.css" rel="stylesheet" />
}

@section Scripts {
    <script src="~/js/HistorialPaciente.js" asp-append-version="true"></script>
}