@using Epsilon.ViewModels

@model IEnumerable<ViewMedicos>

<table class="table table-dark table-hover table-group-divider table-responsive table-sm" id="tablaPacientes">
    <thead>
        @* Cabecera *@
        <tr>
            <th scope="col" class="text-center d-none" width="1%">#</th>
            <th scope="col" class="d-none">IDMEDICO</th>
            <th scope="col">MEDICO</th>
            <th scope="col">DNI</th>
            <th scope="col">TELEFONO</th>
            <th scope="col">CIUDAD</th>
            <th scope="col">ASEGURADO</th>
            <th scope="col">F.ALTA</th>
            <th scope="col">Nº CONSULTAS</th>
            <th scope="col">OPERACIONES</th>
        </tr>
    </thead>

    <tbody id="idBodyTable">

        @if (Model.Count() > 0)
        {
            foreach (var medico in Model)
            {
                <tr id="idFilaPeriodo_" class="text-center">
                    <td class="text-center d-none">
                        <span class="fa-solid fa-user-injured"></span>
                    </td>
                    <td style="text-align:center" class="d-none"> @medico.IdMedico.ToString()</td>
                    <td style="text-align:center"> @medico.NombreMedico?.ToString()</td>
                    <td style="text-align:center"> @medico.DNI?.ToString()</td>
                    <td style="text-align:center"> @medico.Telefono.ToString()</td>
                    <td style="text-align:center"> @medico.NumeroColegiado.ToString()</td>
                    <td>
                        <input id="checkAsegurado" type="checkbox" @(medico.Activo ? "checked=\" checked\"" : "") disabled />
                    </td>
                    <td style="text-align:center"> @medico.FechaContratacion</td>
                    <td style="text-align:center"> @medico.NombreClinica</td>

                    @* OPERACIONES *@
                    <td>
                        <div aria-label="Basic Example">

                            @* Boton Editar Paciente *@
                            <a class="btn btn-sm btn-outline-primary" id="btnEditar" data-id="" onclick="jqGetModalUpdatePaciente(@(medico.IdMedico))">
                                <span class="fa fa-pencil"> </span>
                            </a>

                            @* Boton Eliminar Paciente *@
                            <button class="btn btn-sm btn-outline-danger" style="margin-left:5px;" id="btnEliminar" onclick="jqGetModalDeletePaciente(@medico.IdMedico)">
                                <span class="fa fa-circle-xmark"> </span>
                            </button>

                            @* Boton Mostrar Detalle *@
                            <button class="btn btn-sm btn-outline-light js-toggle-detail" data-id="@medico.IdMedico" style="margin-left:5px;" id="btnMostrarDetalle">
                                <i class="fa fa-angle-double-down" aria-hidden="true"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            }
        }

        @* SI NO HAY RESULTADOS *@
        else
        {
            <tr>
                <td colspan="7" class="text-center">
                    <span class="text-black-50 m-2">(No hay resultados)</span>
                </td>
            </tr>
        }
    </tbody>
</table>

<script>
    function toggleDetail(id, btn) {
        const detail = document.getElementById('detail-' + id);
        // Alterna solo la fila actual
        detail.style.display = detail.style.display === 'none' ? '' : 'none';
    }
</script>


        

<style>

    /* Estilos para el detalle */
    .detail-row td {
        background-color: none;
        color: black;
        border: 1px solid #444 !important; /* marco dark pero visible */
        border-top: none !important; /* evita doble borde con la fila anterior */
        box-shadow: inset 0 0 12px rgba(255, 255, 255, 0.05); /* sombreado interior sutil */
        padding: 5px;
        transition: all 0.7s ease;
    }

        /* Estilo para el hover en la fila de detalle */
        .detail-row td:hover {
            background-color: deepskyblue !important; /* leve cambio al pasar el ratón */
        }

    /* Estilo de contenido detallado */
    .detail-content {
        background-color: #3b3f44;
        color: #f8f9fa;
        padding: 12px;
        border-radius: 0 0 6px 6px;
        box-shadow: inset 0 0 6px rgba(255,255,255,0.05);
        overflow: hidden; /* ocultar contenido al cerrar */
        transition: max-height 0.3s ease; /* transición suave */
    }

    /* Estilo de la tabla de pacientes */
    #tablaPacientes {
        border: 1px solid;
        border-color: deepskyblue;
    }

        /* Estilo contenido y alto de las rows */
        #tablaPacientes td,
        #tablaPacientes th {
            vertical-align: middle !important;
            padding-top: 0.6rem;
            padding-bottom: 0.6rem;
        }

        #tablaPacientes input[type="checkbox"] {
            cursor: not-allowed; /* icono prohibido */
        }

</style>