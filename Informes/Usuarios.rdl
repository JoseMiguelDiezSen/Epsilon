    <DataSet Name="dsUsuarios">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@idUsuario">
            <Value>=Parameters!idUsuario.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT Nombre, Telefono, FotoPerfil FROM Usuarios Where Idusuario = @idUsuario</CommandText>
